# ==========================================
# ML Project Architecture Gitignore
# ==========================================

# 1. Data and Large Artifacts (Crucial)
# Never commit raw or processed datasets to Git. 
data/
*.xlsx
*.parquet
*.jsonl

# 2. Python Environment & Caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ipynb_checkpoints/
.virtualenv/
venv/
env/
.env

# 3. Model Weights and Logs
models/
*.pt
*.pkl
*.joblib
*.h5
logs/
*.log
tensorboard/

# 4. OS and IDE specific files
.DS_Store
.idea/
.vscode/
*.sublime-project